---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Chris Schmidt — ML Engineer at HII Mission Technologies. Five years of experience in data engineering and ML engineering. Portfolio of AI engineering projects and JHU coursework.',
  ogImage = '/images/MyImage.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/jpeg" href="/images/MyImage.jpg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a href="/" class="nav-brand">Chris Schmidt</a>
        <ul class="nav-links">
          <li><a href="/" class:list={[{ active: currentPath === '/' }]}>Home</a></li>
          <li><a href="/about" class:list={[{ active: currentPath.startsWith('/about') }]}>About</a></li>
          <li><a href="/projects" class:list={[{ active: currentPath.startsWith('/projects') }]}>Projects</a></li>
          <li><a href="/thinking" class:list={[{ active: currentPath.startsWith('/thinking') }]}>Thinking</a></li>
          <li><a href="/resume" class:list={[{ active: currentPath.startsWith('/resume') }]}>Resume</a></li>
        </ul>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="container">
        <p>&copy; {new Date().getFullYear()} Chris Schmidt | ML Engineer, HII Mission Technologies | JHU AI Engineering (MSE, expected Dec 2028)</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
