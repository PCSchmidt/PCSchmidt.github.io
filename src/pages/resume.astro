---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Resume — Chris Schmidt"
  description="Resume of Chris Schmidt, Machine Learning Engineer and JHU AI Engineering MSE student."
>
  <section class="section">
    <div class="container">
      <h1 class="section-title">Resume</h1>
      <p class="section-intro">
        Machine Learning Engineer with experience building production ML systems. Currently pursuing
        a Master of Science in Engineering in AI at Johns Hopkins University.
      </p>

      <div class="resume-actions">
        <a
          href="/resume/ChrisSchmidt_Resume.pdf"
          class="btn btn-primary"
          download
        >
          ↓ Download PDF
        </a>
        <a
          href="/resume/ChrisSchmidt_Resume.pdf"
          class="btn btn-outline"
        >
          Open in Browser ↗
        </a>
      </div>

      <div class="resume-preview-wrap">
        <iframe
          src="/resume/ChrisSchmidt_Resume.pdf"
          title="Chris Schmidt Resume"
          class="resume-embed"
          loading="lazy"
        ></iframe>
        <p class="resume-fallback">
          Can't see the PDF?{' '}
          <a href="/resume/ChrisSchmidt_Resume.pdf">
            Click here to open it directly
          </a>.
        </p>
      </div>

      <hr class="divider" />

      <div class="resume-highlights">
        <h2 class="highlights-title">Highlights</h2>
        <div class="highlights-grid">
          <div class="highlight-card">
            <h3 class="highlight-heading">Education</h3>
            <ul class="highlight-list">
              <li>
                <strong>Johns Hopkins University</strong> — MSE, AI Engineering (in progress)
              </li>
              <li>Mathematics background with applied focus</li>
            </ul>
          </div>

          <div class="highlight-card">
            <h3 class="highlight-heading">Core Skills</h3>
            <ul class="highlight-list">
              <li>Machine Learning &amp; Deep Learning (PyTorch, Scikit-learn)</li>
              <li>NLP, LLMs, RAG systems</li>
              <li>MLOps: MLflow, Docker, GitHub Actions, CI/CD</li>
              <li>Python, SQL, cloud deployment</li>
            </ul>
          </div>

          <div class="highlight-card">
            <h3 class="highlight-heading">Focus Areas</h3>
            <ul class="highlight-list">
              <li>Production ML systems &amp; inference optimization</li>
              <li>Model evaluation frameworks</li>
              <li>Applied research in AI Engineering</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .resume-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .resume-preview-wrap {
    background: #f3f4f6;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 1rem;
    overflow: hidden;
  }

  .resume-embed {
    width: 100%;
    height: 720px;
    border: none;
    border-radius: 6px;
    background: white;
  }

  .resume-fallback {
    font-size: 0.85rem;
    color: #9ca3af;
    margin-top: 0.5rem;
    text-align: center;
  }

  .resume-highlights {
    margin-top: 2rem;
  }

  .highlights-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
  }

  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.25rem;
  }

  .highlight-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    padding: 1.25rem;
  }

  .highlight-heading {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #1e40af;
    margin-bottom: 0.75rem;
  }

  .highlight-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .highlight-list li {
    font-size: 0.875rem;
    color: #374151;
    padding-left: 1rem;
    position: relative;
  }

  .highlight-list li::before {
    content: '›';
    position: absolute;
    left: 0;
    color: #1e40af;
    font-weight: 700;
  }

  @media (max-width: 640px) {
    .resume-embed {
      height: 480px;
    }
  }
</style>
