---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const featuredProjects = [
  {
    title: 'Production Inference Optimization Study',
    description:
      'ONNX export, INT8 quantization, and adaptive batching applied to a production sentence-transformer. ~9× throughput improvement on CPU with 74% model size reduction and validated accuracy.',
    tags: ['ONNX', 'PyTorch', 'Sentence Transformers', 'Benchmarking', 'Quantization'],
    status: 'featured' as const,
    timeframe: 'Apr 2026',
    metrics: ['~9× throughput (602 req/s)', '74% model size reduction', '2.9ms p50 latency'],
    github: 'https://github.com/PCSchmidt/inference-optimization-study',
    evidence: 'https://github.com/PCSchmidt/inference-optimization-study/tree/main/evidence',
    guide: 'https://github.com/PCSchmidt/inference-optimization-study/blob/main/DEMO_GUIDE.md',
    paper: 'https://github.com/PCSchmidt/inference-optimization-study/blob/main/notebooks/inference_optimization_study.pdf',
    notebook: 'https://github.com/PCSchmidt/inference-optimization-study/blob/main/notebooks/inference_optimization_study.ipynb',
  },
  {
    title: 'AeroIntel — Real-Time Aviation Intelligence Dashboard',
    description:
      'Real-time ADS-B aviation dashboard with a 3-layer ML anomaly pipeline. Ingests live aircraft positions from two sources, runs Kalman filter smoothing, DBSCAN spatial clustering, and IsolationForest outlier scoring, then pushes enriched GeoJSON over WebSocket to a MapLibre GL frontend. Anomalous aircraft trigger on-demand Claude 3.5 Sonnet natural language explanations.',
    tags: ['Python', 'FastAPI', 'Kalman Filter', 'DBSCAN', 'IsolationForest', 'Claude API', 'Next.js', 'MapLibre GL'],
    status: 'featured' as const,
    timeframe: 'Apr 2026',
    metrics: ['7,800+ live aircraft tracked per pipeline cycle', '5.3s pipeline cycle, <100ms WebSocket push latency', '3-layer anomaly pipeline: Kalman, DBSCAN, IsolationForest'],
    github: 'https://github.com/PCSchmidt/aerointel',
    evidence: 'https://github.com/PCSchmidt/aerointel/tree/main/evidence',
    guide: 'https://github.com/PCSchmidt/aerointel/blob/main/DEMO_GUIDE.md',
  },
  {
    title: 'Optimizer Deep Dive: GD to Adam',
    description:
      'Pure NumPy BGD, SGD+Momentum, Adam + neural net with backprop trained on MNIST. Loss landscape visualization and initialization sensitivity. 29 tests.',
    tags: ['NumPy', 'Optimization', 'Neural Networks', 'Backpropagation'],
    status: 'featured' as const,
    timeframe: 'Spring 2026',
    metrics: ['29 passing tests', '~93% MNIST accuracy (pure NumPy)', '3 optimizers from scratch'],
    github: 'https://github.com/PCSchmidt/optimizer-deep-dive',
    evidence: 'https://github.com/PCSchmidt/optimizer-deep-dive/blob/main/notebooks/optimizer_deep_dive.pdf',
    guide: 'https://github.com/PCSchmidt/optimizer-deep-dive/blob/main/DEMO_GUIDE.md',
    paper: 'https://github.com/PCSchmidt/optimizer-deep-dive/blob/main/notebooks/optimizer_deep_dive.pdf',
    notebook: 'https://github.com/PCSchmidt/optimizer-deep-dive/blob/main/notebooks/optimizer_deep_dive.ipynb',
  },
  {
    title: 'Generative Modeling Study (β-VAE)',
    description:
      'From-scratch β-VAE in PyTorch with systematic β-sweep ablation studying the reconstruction–disentanglement tradeoff. 19 tests with CI.',
    tags: ['PyTorch', 'Generative Models', 'VAE', 'Ablation Study'],
    status: 'featured' as const,
    timeframe: 'Spring 2026',
    metrics: ['6 β-sweep configurations', '19 passing tests', 'Full notebook with outputs (PDF)'],
    github: 'https://github.com/PCSchmidt/generative-modeling-study',
    evidence: 'https://github.com/PCSchmidt/generative-modeling-study/blob/main/notebooks/beta_vae_study.pdf',
    guide: 'https://github.com/PCSchmidt/generative-modeling-study/blob/main/DEMO_GUIDE.md',
    paper: 'https://github.com/PCSchmidt/generative-modeling-study/blob/main/notebooks/beta_vae_study.pdf',
    notebook: 'https://github.com/PCSchmidt/generative-modeling-study/blob/main/notebooks/beta_vae_study.ipynb',
  },
  {
    title: 'Parameter-Efficient Fine-Tuning Study (LoRA)',
    description:
      'Systematic LoRA rank ablation on GPT-2 for dialogue summarization. Trains rank [2,4,8,16] x alpha [8,16,32] adapters on SAMSum, evaluates with ROUGE + BERTScore, and shows diminishing returns beyond rank 8. CPU-only, fully reproducible.',
    tags: ['LoRA', 'PEFT', 'Transformers', 'Fine-Tuning', 'Ablation Study'],
    status: 'featured' as const,
    timeframe: 'Apr 2026',
    metrics: ['5 LoRA configurations ablated', '12 passing tests', '0.65% trainable params (rank 8)'],
    github: 'https://github.com/PCSchmidt/finetuning-study',
    evidence: 'https://github.com/PCSchmidt/finetuning-study/tree/main/results',
    guide: 'https://github.com/PCSchmidt/finetuning-study/blob/main/DEMO_GUIDE.md',
    paper: 'https://github.com/PCSchmidt/finetuning-study/blob/main/notebooks/finetuning_study.pdf',
    notebook: 'https://github.com/PCSchmidt/finetuning-study/blob/main/notebooks/finetuning_study.ipynb',
  },
  {
    title: 'SkillSwap — AI-Powered Skill Bartering Platform',
    description:
      'Full-stack skill-sharing marketplace with AI-powered semantic matching. Users list skills they offer or seek, and an embedding-based backend surfaces the best trade partners using cosine similarity over 384-dim vectors.',
    tags: ['Next.js', 'TypeScript', 'FastAPI', 'pgvector', 'sentence-transformers', 'Supabase'],
    status: 'featured' as const,
    timeframe: 'May 2025 – Present',
    metrics: ['384-dim semantic matching', '23 routes, 10 categories', 'Three-tier architecture (Next.js + FastAPI + Supabase)'],
    github: 'https://github.com/PCSchmidt/skillswapappmvp',
    demo: 'https://skillswapappmvp.vercel.app',
    evidence: 'https://github.com/PCSchmidt/skillswapappmvp/blob/master/README.md',
    guide: 'https://github.com/PCSchmidt/skillswapappmvp/blob/master/DEMO_GUIDE.md',
  },
];
---

<Layout title="Chris Schmidt — ML Engineer & AI Engineering (MSE)">
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-text">
          <h1>Chris Schmidt</h1>
          <p class="hero-subtitle">Machine Learning Engineer</p>
          <p class="hero-desc">
            Building production ML systems and studying AI engineering at Johns Hopkins.
            Background in applied mathematics and data engineering. Focused on inference optimization,
            model evaluation, and the engineering practices that make ML work in production.
          </p>
          <div class="hero-cta">
            <a href="/projects" class="btn btn-primary">View Projects</a>
            <a href="/resume" class="btn btn-outline">Resume</a>
          </div>
          <div class="social-links">
            <a href="https://github.com/PCSchmidt" class="social-link" target="_blank" rel="noopener">
              GitHub
            </a>
            <a href="https://www.linkedin.com/in/pchristopherschmidt/" class="social-link" target="_blank" rel="noopener">
              LinkedIn
            </a>
            <a href="mailto:p.christopher.schmidt@gmail.com" class="social-link" id="email-link" onclick="if(!this.dataset.revealed){event.preventDefault();this.textContent='p.christopher.schmidt@gmail.com';this.dataset.revealed='1';}">Email</a>
          </div>
        </div>
        <div class="hero-image-wrap">
          <img
            src="/images/MyImage.jpg"
            alt="Chris Schmidt"
            class="hero-image"
            width="260"
            height="260"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- About strip -->
  <section class="about-strip">
    <div class="container">
      <div class="about-chips">
        <div class="about-chip">
          <span class="chip-icon">🎓</span>
          <span>MSE AI Engineering — Johns Hopkins University</span>
        </div>
        <div class="about-chip">
          <span class="chip-icon">📐</span>
          <span>MS Applied Mathematics</span>
        </div>
        <div class="about-chip">
          <span class="chip-icon">⚙️</span>
          <span>Inference Optimization &amp; Deployment</span>
        </div>
        <div class="about-chip">
          <span class="chip-icon">🧠</span>
          <span>NLP, LLMs &amp; Deep Learning</span>
        </div>
        <div class="about-chip">
          <span class="chip-icon">📊</span>
          <span>Applied ML Research</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Selected Projects -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Selected Projects</h2>
      <p class="section-intro">
        Highlights from my ML/AI project portfolio — each structured as a case study with
        problem context, approach, and measurable outcomes.
      </p>
      <div class="projects-grid">
        {
          featuredProjects.map((project) => (
            <ProjectCard
              title={project.title}
              description={project.description}
              tags={project.tags}
              status={project.status}
              metrics={project.metrics}
              github={project.github}
              demo={project.demo}
              evidence={project.evidence}
              guide={project.guide}
              timeframe={project.timeframe}
              paper={project.paper}
              notebook={project.notebook}
            />
          ))
        }
      </div>
      <div class="projects-cta">
        <a href="/projects" class="btn btn-outline">View All Projects →</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    padding: 5rem 0 3rem;
    background: linear-gradient(to bottom, #ffffff, #f9fafb);
    border-bottom: 1px solid #e5e7eb;
  }

  .hero-grid {
    display: flex;
    align-items: center;
    gap: 3rem;
  }

  .hero-text {
    flex: 1;
    min-width: 280px;
  }

  .hero-subtitle {
    font-size: 1.05rem;
    font-weight: 600;
    color: #374151;
    margin-bottom: 1.25rem;
  }

  .hero-desc {
    font-size: 0.95rem;
    color: #4b5563;
    margin-bottom: 0.75rem;
    max-width: 520px;
    line-height: 1.75;
  }

  .hero-cta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .social-links {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .social-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: #6b7280;
    transition: color 0.15s;
  }

  .social-link:hover {
    color: #1e40af;
  }

  .hero-image-wrap {
    flex-shrink: 0;
  }

  .hero-image {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    object-fit: cover;
    object-position: top center;
    border: 4px solid #e5e7eb;
    box-shadow: 0 4px 24px rgb(0 0 0 / 0.12);
  }

  /* About strip */
  .about-strip {
    background: #eff6ff;
    padding: 1.25rem 0;
    border-bottom: 1px solid #bfdbfe;
  }

  .about-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .about-chip {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: #1e3a8a;
    background: white;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    border: 1px solid #bfdbfe;
    white-space: nowrap;
  }

  .chip-icon {
    font-size: 0.95rem;
  }

  /* Projects grid */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .projects-cta {
    margin-top: 2rem;
    text-align: center;
  }

  @media (max-width: 640px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
    .hero {
      padding: 3rem 0 2rem;
    }
    .hero-image {
      width: 150px;
      height: 150px;
    }
    .hero-grid {
      flex-direction: column-reverse;
      align-items: flex-start;
    }
  }
</style>
</style>