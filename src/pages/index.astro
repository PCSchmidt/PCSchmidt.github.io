---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const featuredProjects = [
  {
    title: 'ArXiv Research Assistant',
    problem: 'Researchers need to surface relevant literature quickly from a rapidly growing corpus of ML/AI papers on ArXiv.',
    approach: 'Built an end-to-end RAG pipeline using LangChain, a FAISS vector store, and GPT-4 to retrieve, rerank, and synthesize information from ArXiv paper abstracts via a conversational interface.',
    impact: 'Reduced literature-search time in prototype tests; architecture is designed to swap in any embedding model or vector DB for cost/latency tradeoffs.',
    stack: ['Python', 'LangChain', 'FAISS', 'OpenAI GPT-4', 'FastAPI', 'Streamlit'],
    repoUrl: 'https://github.com/PCSchmidt/arxiv-research-assistant',
    demoUrl: 'https://pcschmidt.github.io/arxiv-research-assistant/',
    featured: true,
    badge: 'Featured',
  },
  {
    title: 'Advanced Stock Prediction App',
    problem: 'Financial time-series forecasting is sensitive to non-stationarity, regime shifts, and feature engineering choices.',
    approach: 'Implemented and compared LSTM, Prophet, and classical ARIMA baselines on multi-asset price data; automated feature engineering and hyperparameter search with Optuna.',
    impact: 'Achieved measurably lower RMSE vs. baselines on held-out test windows; identified key seasonal patterns that naive models missed.',
    stack: ['Python', 'PyTorch', 'Prophet', 'Optuna', 'Pandas', 'Plotly'],
    repoUrl: 'https://github.com/PCSchmidt/advanced-stock-prediction-app',
    demoUrl: 'https://pcschmidt.github.io/advanced-stock-prediction-app/',
    featured: true,
    badge: 'Featured',
  },
  {
    title: 'YouTube Transcript Analyzer',
    problem: 'Long-form video content is hard to search, summarize, or extract structured insights from at scale.',
    approach: 'Integrated YouTube Data API for transcript extraction with an LLM summarization layer; outputs structured key-points, sentiment, and topic clusters.',
    impact: 'Demonstrated practical NLP pipeline design from data ingestion through structured output — relevant to content intelligence and enterprise search use cases.',
    stack: ['Python', 'YouTube API', 'OpenAI', 'NLP', 'Streamlit'],
    repoUrl: 'https://github.com/PCSchmidt/youtube_app',
    demoUrl: 'https://pcschmidt.github.io/youtube_app/',
  },
];
---

<Layout title="Home" description="Chris Schmidt — Machine Learning Engineer | JHU AI Engineering (MSE). Portfolio showcasing ML/AI projects.">

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <p class="hero-eyebrow">Hi, I'm</p>
        <h1 class="hero-name">Chris Schmidt</h1>
        <p class="hero-tagline">Machine Learning Engineer | JHU AI Engineering (MSE)</p>
        <p class="hero-bio">
          I build production-grade ML systems — from retrieval-augmented generation pipelines to
          time-series forecasting models — and I'm currently deepening my expertise in applied AI
          through the Master of Science in Engineering (Artificial Intelligence) program at
          <strong>Johns Hopkins University</strong>. My background in applied mathematics gives me
          a rigorous foundation for both the theory and engineering sides of modern machine learning.
        </p>
        <div class="hero-actions">
          <a href="/projects" class="btn btn-primary">View Projects</a>
          <a href="/resume" class="btn btn-secondary">Résumé</a>
        </div>
        <div class="hero-social">
          <a href="https://github.com/PCSchmidt" target="_blank" rel="noopener" class="social-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 4.419 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.579.688.481C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
            </svg>
            GitHub
          </a>
          <a href="https://www.linkedin.com/in/chris-schmidt-94526a10/" target="_blank" rel="noopener" class="social-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/>
            </svg>
            LinkedIn
          </a>
          <a href="mailto:your-email@example.com" class="social-link"><!-- TODO: replace with your real email -->
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            Email
          </a>
        </div>
      </div>
      <div class="hero-photo">
        <img src="/images/MyImage.jpg" alt="Chris Schmidt" class="headshot" loading="eager" />
      </div>
    </div>
  </section>

  <!-- ===== SKILLS SNAPSHOT ===== -->
  <section class="skills-section">
    <div class="container">
      <h2 class="section-heading">Technical Focus</h2>
      <div class="divider"></div>
      <p class="section-subheading">Core competencies across the ML engineering stack</p>
      <div class="skills-grid">
        <div class="skill-group">
          <h3 class="skill-group-title">Machine Learning</h3>
          <ul class="skill-list">
            <li>LLMs &amp; RAG Systems</li>
            <li>Time-Series Forecasting</li>
            <li>Supervised / Unsupervised Learning</li>
            <li>Model Evaluation &amp; Evals</li>
          </ul>
        </div>
        <div class="skill-group">
          <h3 class="skill-group-title">MLOps &amp; Engineering</h3>
          <ul class="skill-list">
            <li>Python · PyTorch · scikit-learn</li>
            <li>LangChain · LlamaIndex</li>
            <li>FastAPI · Streamlit</li>
            <li>Docker · GitHub Actions</li>
          </ul>
        </div>
        <div class="skill-group">
          <h3 class="skill-group-title">Data &amp; Math</h3>
          <ul class="skill-list">
            <li>Applied Mathematics (MSc)</li>
            <li>Pandas · NumPy · Plotly</li>
            <li>Statistical Modeling</li>
            <li>Vector Databases (FAISS)</li>
          </ul>
        </div>
        <div class="skill-group">
          <h3 class="skill-group-title">Education</h3>
          <ul class="skill-list">
            <li>MSE — AI Engineering, Johns Hopkins</li>
            <li>MSc — Applied Mathematics</li>
            <li>BSc — Applied Math, Poli Sci, History</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FEATURED PROJECTS ===== -->
  <section class="featured-projects">
    <div class="container">
      <h2 class="section-heading">Selected Projects</h2>
      <div class="divider"></div>
      <p class="section-subheading">A sample of ML/AI work — see the full <a href="/projects">Projects page</a> for more.</p>
      <div class="projects-grid">
        {featuredProjects.map(project => (
          <ProjectCard {...project} />
        ))}
      </div>
      <div class="projects-cta">
        <a href="/projects" class="btn btn-secondary">All Projects →</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ===== HERO ===== */
  .hero {
    padding: 5rem 0 4rem;
    border-bottom: 1px solid var(--color-border);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: center;
  }

  .hero-eyebrow {
    font-size: 0.9rem;
    color: var(--color-accent);
    font-weight: 500;
    letter-spacing: 0.04em;
    margin-bottom: 0.25rem;
    text-transform: uppercase;
  }

  .hero-name {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 0.6rem;
  }

  .hero-tagline {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    margin-bottom: 1.5rem;
  }

  .hero-bio {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-text-muted);
    max-width: 560px;
    margin-bottom: 2rem;
  }

  .hero-bio strong {
    color: var(--color-text);
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .hero-social {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition);
  }

  .social-link:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .hero-photo {
    flex-shrink: 0;
  }

  .headshot {
    width: 240px;
    height: 240px;
    object-fit: cover;
    border-radius: 50%;
    border: 3px solid var(--color-border);
    box-shadow: 0 0 0 6px rgba(88, 166, 255, 0.08);
  }

  /* ===== SKILLS ===== */
  .skills-section {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
  }

  .skill-group-title {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-accent);
    font-family: var(--font-mono);
    margin-bottom: 0.75rem;
  }

  .skill-list li {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    padding: 0.2rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .skill-list li:last-child {
    border-bottom: none;
  }

  /* ===== FEATURED PROJECTS ===== */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .projects-cta {
    text-align: center;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }

    .hero-photo {
      order: -1;
      text-align: center;
    }

    .headshot {
      width: 180px;
      height: 180px;
      margin: 0 auto;
    }
  }
</style>
