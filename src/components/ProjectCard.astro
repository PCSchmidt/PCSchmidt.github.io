---
export interface Props {
  title: string;
  problem: string;
  approach: string;
  impact: string;
  stack: string[];
  repoUrl?: string;
  demoUrl?: string;
  paperUrl?: string;
  featured?: boolean;
  badge?: string;
}

const {
  title,
  problem,
  approach,
  impact,
  stack,
  repoUrl,
  demoUrl,
  paperUrl,
  featured = false,
  badge,
} = Astro.props;
---

<article class:list={['project-card', { featured }]}>
  {badge && <span class="card-badge">{badge}</span>}
  <div class="card-body">
    <h3 class="card-title">{title}</h3>

    <dl class="card-details">
      <div class="detail-row">
        <dt>Problem</dt>
        <dd>{problem}</dd>
      </div>
      <div class="detail-row">
        <dt>Approach</dt>
        <dd>{approach}</dd>
      </div>
      <div class="detail-row">
        <dt>Impact</dt>
        <dd>{impact}</dd>
      </div>
    </dl>

    <div class="tag-list">
      {stack.map(tech => <span class="tag">{tech}</span>)}
    </div>

    <div class="card-links">
      {repoUrl && (
        <a href={repoUrl} target="_blank" rel="noopener" class="card-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.419 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.579.688.481C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
          </svg>
          Repository
        </a>
      )}
      {demoUrl && (
        <a href={demoUrl} target="_blank" rel="noopener" class="card-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
            <polyline points="15 3 21 3 21 9"/>
            <line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
          Live Demo
        </a>
      )}
      {paperUrl && (
        <a href={paperUrl} target="_blank" rel="noopener" class="card-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10 9 9 9 8 9"/>
          </svg>
          Write-up
        </a>
      )}
    </div>
  </div>
</article>

<style>
  .project-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.75rem;
    position: relative;
    transition: border-color var(--transition), transform var(--transition);
  }

  .project-card:hover {
    border-color: var(--color-accent-subtle);
    transform: translateY(-2px);
  }

  .project-card.featured {
    border-color: var(--color-accent-subtle);
  }

  .card-badge {
    position: absolute;
    top: -1px;
    right: 1.25rem;
    background: var(--color-accent-dark);
    color: var(--color-accent);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.2rem 0.6rem;
    border-radius: 0 0 6px 6px;
    border: 1px solid var(--color-accent-subtle);
    border-top: none;
  }

  .card-title {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .card-details {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 1rem;
  }

  .detail-row {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 0.5rem;
    align-items: baseline;
  }

  .detail-row dt {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-accent);
    font-family: var(--font-mono);
    padding-top: 0.15rem;
  }

  .detail-row dd {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .card-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-text-muted);
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    transition: all var(--transition);
    text-decoration: none;
  }

  .card-link:hover {
    color: var(--color-accent);
    border-color: var(--color-accent-subtle);
    background: rgba(31, 111, 235, 0.08);
    text-decoration: none;
  }
</style>
