---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('thinking');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} — Chris Schmidt`} description={post.data.description}>
  <article class="container section article">
    <a href="/thinking" class="back-link">&larr; All posts</a>

    <header class="article-header">
      <h1>{post.data.title}</h1>
      <div class="article-meta">
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
        {post.data.tags && (
          <div class="article-tags">
            {post.data.tags.map((tag: string) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </div>
    </header>

    <div class="article-body">
      <Content />
    </div>

    <footer class="article-footer">
      <a href="/thinking" class="back-link">&larr; All posts</a>
    </footer>
  </article>
</Layout>

<style>
  .article {
    max-width: 720px;
  }

  .back-link {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--color-accent);
    text-decoration: none;
    margin-bottom: 2rem;
    font-weight: 500;
  }

  .back-link:hover {
    color: var(--color-accent-light);
  }

  .article-header {
    margin-bottom: 2.5rem;
  }

  .article-header h1 {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    line-height: 1.3;
    margin-bottom: 1rem;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .article-meta time {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .article-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .article-body {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .article-body :global(h2) {
    font-size: 1.4rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .article-body :global(h3) {
    font-size: 1.15rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .article-body :global(p) {
    margin-bottom: 1.25rem;
    color: var(--color-text);
  }

  .article-body :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .article-body :global(a:hover) {
    color: var(--color-accent-light);
  }

  .article-body :global(strong) {
    font-weight: 700;
    color: var(--color-text);
  }

  .article-body :global(ul), .article-body :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .article-body :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }

  .article-body :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .article-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--color-tag-bg);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .article-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }
</style>
