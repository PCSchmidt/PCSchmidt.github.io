---
interface Props {
  title: string;
  description: string;
  tags: string[];
  status: 'featured' | 'in-progress' | 'placeholder';
  github?: string;
  demo?: string;
  evidence?: string;
  guide?: string;
  paper?: string;
  notebook?: string;
  metrics?: string[];
  timeframe?: string;
}

const { title, description, tags, status, github, demo, evidence, guide, paper, notebook, metrics, timeframe } = Astro.props;

const statusLabel: Record<string, string> = {
  featured: 'Featured',
  'in-progress': 'In Progress',
  placeholder: 'Coming Soon',
};
const statusColor: Record<string, string> = {
  featured: '#dcfce7',
  'in-progress': '#fef9c3',
  placeholder: '#f3f4f6',
};
const statusTextColor: Record<string, string> = {
  featured: '#15803d',
  'in-progress': '#854d0e',
  placeholder: '#4b5563',
};
---

<article class="card project-card">
  <header class="project-header">
    <div class="project-title-row">
      <h3 class="project-title">{title}</h3>
      <div class="project-meta">
        {timeframe && <span class="project-timeframe">{timeframe}</span>}
        <span
          class="project-status"
          style={`background:${statusColor[status]};color:${statusTextColor[status]}`}
        >
          {statusLabel[status]}
        </span>
      </div>
    </div>
    <p class="project-description">{description}</p>
  </header>

  <slot />

  {metrics && metrics.length > 0 && (
    <div class="project-metrics">
      {metrics.map((m) => (
        <div class="metric-chip">{m}</div>
      ))}
    </div>
  )}

  <footer class="project-footer">
    <div class="project-tags">
      {tags.map((tag) => (
        <span class="tag">{tag}</span>
      ))}
    </div>
    <div class="project-links">
      {github && (
        <a href={github} class="project-link">
          GitHub ↗
        </a>
      )}
      {demo && (
        <a href={demo} class="project-link">
          Demo ↗
        </a>
      )}
      {evidence && (
        <a href={evidence} class="project-link">
          Evidence ↗
        </a>
      )}
      {guide && (
        <a href={guide} class="project-link">
          Demo Guide ↗
        </a>
      )}
      {paper && (
        <a href={paper} class="project-link">
          Paper ↗
        </a>
      )}
      {notebook && (
        <a href={notebook} class="project-link">
          Notebook ↗
        </a>
      )}
    </div>
  </footer>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .project-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .project-title-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .project-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #111827;
    margin: 0;
  }

  .project-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .project-timeframe {
    font-size: 0.78rem;
    color: #6b7280;
    white-space: nowrap;
  }

  .project-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .project-timeframe {
    font-size: 0.78rem;
    color: #6b7280;
    white-space: nowrap;
  }

  .project-status {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    white-space: nowrap;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    flex-shrink: 0;
  }

  .project-description {
    font-size: 0.9rem;
    color: #6b7280;
    line-height: 1.6;
    margin: 0;
  }

  .project-metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .metric-chip {
    background: #eff6ff;
    color: #1e40af;
    border: 1px solid #bfdbfe;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.25rem 0.65rem;
    border-radius: var(--radius, 8px);
  }

  .project-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid #e5e7eb;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .project-links {
    display: flex;
    gap: 1rem;
  }

  .project-link {
    font-size: 0.82rem;
    font-weight: 600;
    color: #1e40af;
    text-decoration: none;
    transition: color 0.15s;
  }

  .project-link:hover {
    color: #3b82f6;
  }
</style>
