---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const featuredProjects = [
  {
    title: 'SkillSwap — AI-Powered Skill Bartering Platform',
    description:
      'Full-stack skill-sharing marketplace with AI-powered semantic matching. Users list skills they offer or seek, and an embedding-based backend surfaces the best trade partners using cosine similarity over 384-dim vectors.',
    tags: ['Next.js', 'TypeScript', 'FastAPI', 'pgvector', 'sentence-transformers', 'Supabase'],
    status: 'featured' as const,
    metrics: ['384-dim semantic matching', '23 routes, 10 categories', 'Three-tier production deploy'],
    github: 'https://github.com/PCSchmidt/skillswapappmvp',
    demo: 'https://skillswapappmvp.vercel.app',
    evidence: 'https://github.com/PCSchmidt/skillswapappmvp/blob/master/README.md',
    guide: 'https://github.com/PCSchmidt/skillswapappmvp/blob/master/DEMO_GUIDE.md',
  },
  {
    title: 'Production Inference Optimization Study',
    description:
      'ONNX export, INT8 quantization, and adaptive batching applied to a production sentence-transformer. ~9× throughput improvement on CPU with 74% model size reduction and validated accuracy.',
    tags: ['ONNX', 'PyTorch', 'Sentence Transformers', 'Benchmarking', 'Quantization'],
    status: 'featured' as const,
    metrics: ['~9× throughput (602 req/s)', '74% model size reduction', '2.9ms p50 latency'],
    github: 'https://github.com/PCSchmidt/inference-optimization-study',
    evidence: 'https://github.com/PCSchmidt/inference-optimization-study/tree/main/evidence',
    guide: 'https://github.com/PCSchmidt/inference-optimization-study/blob/main/DEMO_GUIDE.md',
  },
  {
    title: 'Generative AI Journal Summarizer (RAG)',
    description:
      'RAG-based summarization workflow for journal entries and long-form documents, focused on grounded summaries and cleaner retrieval quality as the corpus scales.',
    tags: ['Python', 'RAG', 'LangChain', 'NLP'],
    status: 'featured' as const,
    metrics: ['Document-to-summary workflow', 'Retrieval-augmented context', 'Production-oriented architecture'],
    github: 'https://github.com/PCSchmidt/generative-ai-journal-summarizer',
    demo: 'https://generative-ai-journal-summarizer.vercel.app',
    evidence: 'https://github.com/PCSchmidt/generative-ai-journal-summarizer/tree/main/evidence/reliability-2026-04-12-final-confirmed',
    guide: 'https://github.com/PCSchmidt/generative-ai-journal-summarizer/blob/main/DEMO_GUIDE.md',
  },
  {
    title: 'LearnOnTheGo — Prompt/PDF to Audio Lectures',
    description:
      'End-to-end AI application that converts prompts and uploaded PDFs into generated audio lecture content, with evidence-first documentation of flow and constraints.',
    tags: ['Full Stack', 'Generative AI', 'Audio', 'Document Processing'],
    status: 'featured' as const,
    metrics: ['Prompt + file input modes', 'AI-generated learning output', 'Evidence-linked project narrative'],
    github: 'https://github.com/PCSchmidt/learnonthego',
    demo: 'https://learnonthego-bice.vercel.app',
    evidence: 'https://github.com/PCSchmidt/learnonthego/blob/main/README.md',
    guide: 'https://github.com/PCSchmidt/learnonthego/blob/main/DEMO_GUIDE.md',
  },
  {
    title: 'Generative Modeling Study (β-VAE)',
    description:
      'From-scratch β-VAE in PyTorch with systematic β-sweep ablation studying the reconstruction–disentanglement tradeoff. 19 tests with CI.',
    tags: ['PyTorch', 'Generative Models', 'VAE', 'Ablation Study'],
    status: 'featured' as const,
    metrics: ['6 β-sweep configurations', '19 passing tests', 'Evidence PNGs exported'],
    github: 'https://github.com/PCSchmidt/generative-modeling-study',
    evidence: 'https://github.com/PCSchmidt/generative-modeling-study/tree/main/evidence',
    guide: 'https://github.com/PCSchmidt/generative-modeling-study/blob/main/DEMO_GUIDE.md',
  },
  {
    title: 'RL Environment + Q-Learning Study',
    description:
      'Custom Windy Gridworld with tabular Q-learning and DQN agents from scratch using Gymnasium and PyTorch. 24 tests with CI.',
    tags: ['Reinforcement Learning', 'PyTorch', 'Gymnasium', 'DQN'],
    status: 'featured' as const,
    metrics: ['24 passing tests', 'Tabular + Deep RL agents', 'Custom Gymnasium environment'],
    github: 'https://github.com/PCSchmidt/rl-environment-study',
    evidence: 'https://github.com/PCSchmidt/rl-environment-study/tree/main/evidence',
    guide: 'https://github.com/PCSchmidt/rl-environment-study/blob/main/DEMO_GUIDE.md',
  },
  {
    title: 'Optimizer Deep Dive: GD to Adam',
    description:
      'Pure NumPy BGD, SGD+Momentum, Adam + neural net with backprop trained on MNIST. Loss landscape visualization and initialization sensitivity. 29 tests.',
    tags: ['NumPy', 'Optimization', 'Neural Networks', 'Backpropagation'],
    status: 'featured' as const,
    metrics: ['29 passing tests', '~93% MNIST accuracy (pure NumPy)', '3 optimizers from scratch'],
    github: 'https://github.com/PCSchmidt/optimizer-deep-dive',
    evidence: 'https://github.com/PCSchmidt/optimizer-deep-dive/tree/main/evidence',
    guide: 'https://github.com/PCSchmidt/optimizer-deep-dive/blob/main/DEMO_GUIDE.md',
  },
];
---

<Layout title="Chris Schmidt — ML Engineer & JHU AI Engineering MSE">
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-text">
          <p class="hero-eyebrow">Hi, I'm</p>
          <h1 class="hero-name">Chris Schmidt</h1>
          <p class="hero-tagline">Machine Learning Engineer | MS Applied Mathematics | JHU AI Engineering (MSE)</p>
          <p class="hero-bio">
            I build machine learning systems that work in production — from data pipelines and model
            training to deployment, monitoring, and continuous improvement. With a Master's in
            Applied Mathematics and a current MSE in AI Engineering at Johns Hopkins University,
            I bring mathematical rigor to deep learning, optimization, and applied ML research.
          </p>
          <p class="hero-bio">
            My work sits at the intersection of applied mathematics and production engineering:
            designing scalable inference services, optimizing model performance with quantization
            and batching strategies, and shipping models that create measurable impact.
          </p>
          <div class="hero-actions">
            <a href="/projects" class="btn btn-primary">View Projects</a>
            <a href="/resume" class="btn btn-outline">Resume</a>
          </div>
          <div class="hero-social">
            <a
              href="https://github.com/PCSchmidt"
              class="social-link"
            >
              GitHub
            </a>
            <a
              href="https://www.linkedin.com/in/chris-schmidt-94526a10/"
              class="social-link"
            >
              LinkedIn
            </a>
            <a href="mailto:p.christopher.schmidt@gmail.com" class="social-link">Email</a>
          </div>
        </div>
        <div class="hero-image-wrap">
          <img
            src="/images/MyImage.jpg"
            alt="Chris Schmidt"
            class="hero-image"
            width="260"
            height="260"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- About strip -->
  <section class="about-strip">
    <div class="container">
      <div class="about-chips">
        <div class="about-chip">
          <span class="chip-icon">🎓</span>
          <span>MSE AI Engineering — Johns Hopkins University</span>
        </div>
        <div class="about-chip">
          <span class="chip-icon">📐</span>
          <span>MS Applied Mathematics</span>
        </div>
        <div class="about-chip">
          <span class="chip-icon">⚙️</span>
          <span>MLOps &amp; Production ML Systems</span>
        </div>
        <div class="about-chip">
          <span class="chip-icon">🧠</span>
          <span>NLP, LLMs &amp; Deep Learning</span>
        </div>
        <div class="about-chip">
          <span class="chip-icon">📊</span>
          <span>Applied ML Research</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Selected Projects -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Selected Projects</h2>
      <p class="section-intro">
        A snapshot of flagship ML/AI projects. Each entry is structured as a case study with
        problem context, approach, and measurable outcomes.
        <br />
        <em style="font-size:0.85rem; color:#9ca3af;">
          Projects marked "In Progress" are actively being hardened with deeper evaluation and deployment polish.
        </em>
      </p>
      <div class="projects-grid">
        {
          featuredProjects.map((project) => (
            <ProjectCard
              title={project.title}
              description={project.description}
              tags={project.tags}
              status={project.status}
              metrics={project.metrics}
              github={project.github}
              demo={project.demo}
              evidence={project.evidence}
              guide={project.guide}
            />
          ))
        }
      </div>
      <div class="projects-cta">
        <a href="/projects" class="btn btn-outline">View All Projects →</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    padding: 5rem 0 3rem;
    background: linear-gradient(to bottom, #ffffff, #f9fafb);
    border-bottom: 1px solid #e5e7eb;
  }

  .hero-inner {
    display: flex;
    align-items: center;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .hero-text {
    flex: 1;
    min-width: 280px;
  }

  .hero-eyebrow {
    font-size: 0.9rem;
    font-weight: 600;
    color: #1e40af;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.35rem;
  }

  .hero-name {
    font-size: clamp(2.25rem, 5vw, 3.25rem);
    font-weight: 800;
    color: #0f172a;
    line-height: 1.15;
    margin-bottom: 0.5rem;
  }

  .hero-tagline {
    font-size: 1.05rem;
    font-weight: 600;
    color: #374151;
    margin-bottom: 1.25rem;
  }

  .hero-bio {
    font-size: 0.95rem;
    color: #4b5563;
    margin-bottom: 0.75rem;
    max-width: 520px;
    line-height: 1.75;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .hero-social {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .social-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: #6b7280;
    transition: color 0.15s;
  }

  .social-link:hover {
    color: #1e40af;
  }

  .hero-image-wrap {
    flex-shrink: 0;
  }

  .hero-image {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    object-fit: cover;
    object-position: top center;
    border: 4px solid #e5e7eb;
    box-shadow: 0 4px 24px rgb(0 0 0 / 0.12);
  }

  /* About strip */
  .about-strip {
    background: #eff6ff;
    padding: 1.25rem 0;
    border-bottom: 1px solid #bfdbfe;
  }

  .about-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .about-chip {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: #1e3a8a;
    background: white;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    border: 1px solid #bfdbfe;
    white-space: nowrap;
  }

  .chip-icon {
    font-size: 0.95rem;
  }

  /* Projects grid */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .projects-cta {
    margin-top: 2rem;
    text-align: center;
  }

  @media (max-width: 640px) {
    .hero {
      padding: 3rem 0 2rem;
    }
    .hero-image {
      width: 150px;
      height: 150px;
    }
    .hero-inner {
      flex-direction: column-reverse;
      align-items: flex-start;
    }
  }
</style>
