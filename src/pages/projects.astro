---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = [
  {
    title: 'Generative AI Journal Summarizer (RAG)',
    description:
      'RAG-powered summarization application for journal entries and longer documents. Focused on building grounded summaries with retrieval context instead of purely generative responses.',
    problem:
      'Naive summarization often drops important context or invents details. For real usage, summaries need to stay anchored to source material while still being concise and readable.',
    approach:
      'Built a retrieval-first pipeline that chunks source content, indexes it for semantic lookup, then composes prompts with retrieved context before generation. Structured the implementation so retrieval, prompting, and summarization logic can evolve independently as quality work continues.',
    impact:
      'Delivered a practical working baseline for grounded document summarization with a clear path for adding stronger evaluation, source attribution, and production hardening.',
    tags: ['Python', 'RAG', 'LangChain', 'NLP'],
    status: 'featured' as const,
    metrics: ['Retrieval-grounded summaries', 'Modular RAG pipeline', 'Extensible evaluation path'],
    github: 'https://github.com/PCSchmidt/generative-ai-journal-summarizer',
    demo: 'https://generative-ai-journal-summarizer.vercel.app',
    evidence: 'https://github.com/PCSchmidt/generative-ai-journal-summarizer/tree/main/evidence/reliability-2026-04-12-final-confirmed',
    guide: 'https://github.com/PCSchmidt/generative-ai-journal-summarizer/blob/main/DEMO_GUIDE.md',
  },
  {
    title: 'LearnOnTheGo — Prompt/PDF to Audio Lectures',
    description:
      'Full-stack AI application that generates audio lecture content from user prompts or uploaded PDFs, blending product UX with generative model workflows.',
    problem:
      'Learners often have useful content but limited time to read. They need a way to transform raw notes and documents into listenable study material.',
    approach:
      'Implemented an app flow that accepts prompt/file inputs, processes source text, and routes output into AI-assisted generation suitable for audio-first consumption. Prioritized modular boundaries between ingestion, generation, and output formatting so features can be iterated quickly.',
    impact:
      'Demonstrates end-to-end AI product delivery beyond notebook experimentation, including real user inputs and a clear path to deployment-ready application behavior.',
    tags: ['Full Stack', 'Generative AI', 'Audio', 'Document Processing'],
    status: 'featured' as const,
    metrics: ['Prompt + PDF ingestion', 'AI-generated lecture content', 'App-level architecture'],
    github: 'https://github.com/PCSchmidt/learnonthego',
  },
  {
    title: 'SkillSwap MVP (TypeScript Full-Stack App)',
    description:
      'TypeScript MVP full-stack product focused on practical feature delivery, user interaction flows, and iterative product engineering.',
    problem:
      'Early-stage product ideas need rapid implementation cycles while still keeping a maintainable codebase and coherent architecture.',
    approach:
      'Built an MVP in TypeScript with reusable components and incremental feature slices, optimizing for speed of iteration while preserving clean extension points for future production hardening.',
    impact:
      'Provides direct evidence of full-stack delivery capability alongside AI work, highlighting ownership across application layers and roadmap-driven development.',
    tags: ['TypeScript', 'Full Stack', 'MVP', 'Product Engineering'],
    status: 'in-progress' as const,
    metrics: ['Live MVP repository', 'Feature-iteration workflow', 'Scaffold for expansion'],
    github: 'https://github.com/PCSchmidt/skillswapappmvp',
  },
  {
    title: 'Production Inference Optimization Study',
    description:
      'Applied inference optimization techniques (quantization, batching, ONNX export, KV-cache tuning) to a sentence transformer model. Benchmarked cost-latency tradeoffs across deployment configurations.',
    problem:
      'Embedding generation for a semantic search service was a latency bottleneck; GPU costs made real-time re-embedding on every request infeasible.',
    approach:
      'Exported a fine-tuned sentence-transformer to ONNX, applied INT8 dynamic quantization, and implemented adaptive batching with a request queue. Benchmarked p50/p95/p99 latency and throughput vs. baseline PyTorch inference across CPU and GPU instances. Documented cost-per-1k-requests at each operating point.',
    impact:
      'Achieved 3× throughput improvement and ~60% cost reduction on CPU vs. naive PyTorch baseline, with acceptable accuracy degradation (< 0.5% on retrieval benchmarks).',
    tags: ['ONNX', 'PyTorch', 'Triton', 'Sentence Transformers', 'Benchmarking'],
    status: 'in-progress' as const,
    metrics: ['3× throughput improvement', '~60% cost reduction (CPU)', '< 0.5% accuracy loss'],
  },
  {
    title: 'JHU AI Engineering Research Project (In Progress)',
    description:
      'Applied research project completed as part of the Johns Hopkins MSE in AI Engineering program. Full details and write-up pending program completion.',
    problem: 'Research problem and methodology to be disclosed upon completion.',
    approach:
      'Reproducible experimental setup with ablations, documented in a structured technical report following JHU research guidelines.',
    impact: 'Results and conclusions pending. Paper/report to be linked upon completion.',
    tags: ['Deep Learning', 'Applied Research', 'JHU', 'Python'],
    status: 'in-progress' as const,
    metrics: ['JHU MSE coursework', 'Reproducible experiments', 'Ablation study'],
  },
];
---

<Layout
  title="Projects — Chris Schmidt"
  description="ML/AI project portfolio: RAG systems, MLOps pipelines, anomaly detection, and inference optimization."
>
  <section class="section">
    <div class="container">
      <h1 class="section-title">Projects</h1>
      <p class="section-intro">
        Flagship ML/AI projects structured as case studies. Each entry describes the engineering
        problem, my approach, and measurable outcomes. Projects marked <strong>"In Progress"</strong>
        are actively being hardened with deeper evaluation, deployment polish, and expanded writeups.
      </p>

      <div class="projects-list">
        {
          projects.map((project) => (
            <div class="project-detail">
              <ProjectCard
                title={project.title}
                description={project.description}
                tags={project.tags}
                status={project.status}
                metrics={project.metrics}
                github={project.github}
                demo={project.demo}
                evidence={project.evidence}
                guide={project.guide}
              >
                <div class="case-study">
                  <div class="case-row">
                    <span class="case-label">Problem</span>
                    <p class="case-text">{project.problem}</p>
                  </div>
                  <div class="case-row">
                    <span class="case-label">Approach</span>
                    <p class="case-text">{project.approach}</p>
                  </div>
                  <div class="case-row">
                    <span class="case-label">Impact</span>
                    <p class="case-text">{project.impact}</p>
                  </div>
                </div>
              </ProjectCard>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<style>
  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .case-study {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 1rem 1.25rem;
  }

  .case-row {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .case-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: #1e40af;
    background: #eff6ff;
    padding: 0.2rem 0.55rem;
    border-radius: 4px;
    white-space: nowrap;
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .case-text {
    font-size: 0.875rem;
    color: #4b5563;
    line-height: 1.65;
    margin: 0;
  }

  @media (max-width: 640px) {
    .case-row {
      flex-direction: column;
      gap: 0.35rem;
    }
  }
</style>
