---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('thinking')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Thinking — Chris Schmidt">
  <section class="container section">
    <h1 class="section-title">Thinking</h1>
    <p class="section-intro">
      Notes on AI engineering, mathematical foundations, and the shifting landscape
      of what it means to build intelligent systems.
    </p>

    <div class="posts-list">
      {posts.map((post) => (
        <a href={`/thinking/${post.id}`} class="post-card">
          <div class="post-meta">
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
            {post.data.tags && (
              <div class="post-tags">
                {post.data.tags.map((tag: string) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
          <h2 class="post-title">{post.data.title}</h2>
          <p class="post-description">{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .post-card {
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem 2rem;
    text-decoration: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .post-card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-md);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .post-meta time {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .post-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .post-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }

  .post-description {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }
</style>
