---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Resume — Chris Schmidt"
  description="Resume of Chris Schmidt, Machine Learning Engineer and JHU AI Engineering MSE student."
>
  <section class="section">
    <div class="container">
      <h1 class="section-title">Resume</h1>
      <p class="section-intro">
        Five years of experience across data engineering, software development, and ML engineering at HII Mission Technologies. Currently supporting DoD data modernization programs and pursuing an MSE in AI Engineering at Johns Hopkins University.
      </p>

      <div class="resume-actions">
        <a
          href="/resume/ChrisSchmidt_Resume.pdf"
          class="btn btn-primary"
          download
        >
          ↓ Download PDF
        </a>
        <a
          href="/resume/ChrisSchmidt_Resume.pdf"
          class="btn btn-outline"
        >
          Open in Browser ↗
        </a>
      </div>

      <div class="resume-preview-wrap">
        <iframe
          src="/resume/ChrisSchmidt_Resume.pdf"
          title="Chris Schmidt Resume"
          class="resume-embed"
          loading="lazy"
        ></iframe>
        <p class="resume-fallback">
          Can't see the PDF?{' '}
          <a href="/resume/ChrisSchmidt_Resume.pdf">
            Click here to open it directly
          </a>.
        </p>
      </div>

      <hr class="divider" />

      <div class="exp-section">
        <h2 class="exp-section-title">Work Experience</h2>

        <div class="exp-entry">
          <div class="exp-header">
            <span class="exp-company">HII Mission Technologies</span>
            <span class="exp-role-dates">Machine Learning Engineer, F-35 Joint Program Office | 2022 – present</span>
          </div>
          <ul class="exp-bullets">
            <li>Supporting the F-35 JPO data modernization initiative on AWS GovCloud using Python and SQL.</li>
            <li>Build and maintain data analysis scripts, notebooks, and pipelines on the Advana platform.</li>
          </ul>
        </div>

        <div class="exp-entry">
          <div class="exp-header">
            <span class="exp-company">HII Mission Technologies</span>
            <span class="exp-role-dates">Data Engineer / Software Engineer, Fortis AI | 2021 – 2022</span>
          </div>
          <ul class="exp-bullets">
            <li>Data engineering on the Fortis AI project: streaming telemetry, GIS pipelines, GDELT ingestion, and RDF/SPARQL graph work.</li>
            <li>Reviewed pull requests, maintained CI configuration, and drafted technical documentation.</li>
          </ul>
        </div>
      </div>

      <div class="exp-section">
        <h2 class="exp-section-title">Education</h2>

        <div class="exp-entry">
          <div class="exp-header">
            <span class="exp-company">Johns Hopkins University</span>
            <span class="exp-role-dates">MSE, AI Engineering | 2025 – December 2028 (expected)</span>
          </div>
        </div>

        <div class="exp-entry">
          <div class="exp-header">
            <span class="exp-company">Towson University</span>
            <span class="exp-role-dates">MS, Applied Mathematics | 2019 – 2021</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .resume-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .resume-preview-wrap {
    background: #f3f4f6;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 1rem;
    overflow: hidden;
  }

  .resume-embed {
    width: 100%;
    height: 720px;
    border: none;
    border-radius: 6px;
    background: white;
  }

  .resume-fallback {
    font-size: 0.85rem;
    color: #9ca3af;
    margin-top: 0.5rem;
    text-align: center;
  }

  .exp-section {
    margin-top: 2rem;
  }

  .exp-section-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #e5e7eb;
  }

  .exp-entry {
    margin-bottom: 1.5rem;
  }

  .exp-header {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    margin-bottom: 0.5rem;
  }

  .exp-company {
    font-weight: 700;
    font-size: 1rem;
    color: #111827;
  }

  .exp-role-dates {
    font-size: 0.875rem;
    color: #6b7280;
  }

  .exp-bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .exp-bullets li {
    font-size: 0.875rem;
    color: #374151;
    padding-left: 1rem;
    position: relative;
  }

  .exp-bullets li::before {
    content: '\203A';
    position: absolute;
    left: 0;
    color: #1e40af;
    font-weight: 700;
  }

  @media (max-width: 640px) {
    .resume-embed {
      height: 480px;
    }
  }
</style>
